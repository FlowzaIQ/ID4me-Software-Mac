{
  "name": "id4me-scraper",
  "version": "1.0.0",
  "description": "ID4Me Automation Tool",
  "main": "main.js",
  "author": "Your Name",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "test": "node tests/absentee.test.js && node tests/date.test.js && node tests/network.test.js"
  },
  "build": {
    "appId": "com.yourname.id4me-scraper",
    "productName": "ID4Me Scraper",
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/favicon2.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    }
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "csv-parse": "^5.5.5",
    "csv-stringify": "^6.4.6",
    "playwright": "^1.42.0"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^26.8.1"
  }
}
